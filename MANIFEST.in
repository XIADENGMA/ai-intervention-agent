# R76 起本项目使用 hatchling 构建（见 ``pyproject.toml`` 的
# ``[tool.hatch.build.targets.{wheel,sdist}]``），hatchling 不读 MANIFEST.in。
# 此文件仅为一些下游打包工具（setuptools fallback、gentoo / nixpkgs 自动检
# 测脚本等）保留兼容声明：所有源码与资源都在 ``src/ai_intervention_agent/`` 下，
# 配置模板留在仓库根。
include README.md
include LICENSE
include config.toml.default
include config.jsonc.default
recursive-include src/ai_intervention_agent *.py *.html *.json *.svg *.ico *.css *.js *.woff *.woff2 *.ttf *.png *.gif *.lottie *.wav *.mp3 *.webmanifest
global-exclude __pycache__
global-exclude *.py[co]
global-exclude .DS_Store
