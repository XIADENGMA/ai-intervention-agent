{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "types": ["node"],
    "outDir": "./dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "allowJs": true,
    "checkJs": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true
  },
  "include": [
    "extension.ts",
    "logger.ts",
    "webview.ts",
    "applescript-executor.ts",
    "notification-models.ts",
    "notification-center.ts",
    "notification-providers.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    ".vscode-test",
    "test"
  ]
}
