{
  "name": "ai-intervention-agent",
  "displayName": "%displayName%",
  "description": "%description%",
  "version": "1.5.14",
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.105.0"
  },
  "publisher": "xiadengma",
  "repository": {
    "type": "git",
    "url": "https://github.com/XIADENGMA/ai-intervention-agent.git"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:aiInterventionAgent.feedbackView",
    "onCommand:ai-intervention-agent.openPanel",
    "onCommand:ai-intervention-agent.openSettings"
  ],
  "main": "./dist/extension.js",
  "files": [
    "LICENSE",
    "activity-icon.svg",
    "icon.png",
    "icon.svg",
    "dist/**/*.js",
    "dist/**/*.js.map",
    "webview-ui.js",
    "webview-helpers.js",
    "webview-notify-core.js",
    "webview-settings-ui.js",
    "i18n.js",
    "prism-bootstrap.js",
    "webview.css",
    "vendor/terminal-notifier/**",
    "lottie/**",
    "mathjax/**",
    "lottie.min.js",
    "marked.min.js",
    "prism.min.css",
    "prism.min.js",
    "locales/**",
    "package.nls.json",
    "package.nls.zh-CN.json",
    "README.md",
    "README.zh-CN.md"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "aiInterventionAgent",
          "title": "%viewContainer.title%",
          "icon": "activity-icon.svg"
        }
      ]
    },
    "views": {
      "aiInterventionAgent": [
        {
          "type": "webview",
          "id": "aiInterventionAgent.feedbackView",
          "name": ""
        }
      ]
    },
    "commands": [
      {
        "command": "ai-intervention-agent.openPanel",
        "title": "%command.openPanel%"
      },
      {
        "command": "ai-intervention-agent.openSettings",
        "title": "%command.openSettings%"
      }
    ],
    "configuration": {
      "title": "AI Intervention Agent",
      "properties": {
        "ai-intervention-agent.serverUrl": {
          "type": "string",
          "default": "http://localhost:8080",
          "description": "%config.serverUrl.description%"
        },
        "ai-intervention-agent.logLevel": {
          "type": "string",
          "enum": [
            "error",
            "warn",
            "info",
            "debug"
          ],
          "default": "info",
          "description": "%config.logLevel.description%"
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p .",
    "watch": "tsc -p . --watch",
    "lint": "eslint .",
    "package": "node ../../scripts/package_vscode_vsix.mjs",
    "pretest": "npm run compile && npm run lint",
    "test": "vscode-test --config .vscode-test.mjs",
    "check": "npm test && npm run package"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.105.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.34.0",
    "typescript": "^6.0.2"
  }
}
