# AI Intervention Agent 配置文件 / Configuration File
# 文档 / Docs：docs/api.zh-CN/config_manager.md | docs/api/config_manager.md

# ──────────────────────────────────────────────
# 通知配置 / Notification Settings
# ──────────────────────────────────────────────
[notification]
# 总开关 / Master switch
enabled = true
# 调试模式（仅影响通知模块日志详细程度）/ Debug mode (only affects notification module log verbosity)
debug = false
# Web浏览器通知 / Web browser notifications
web_enabled = true
auto_request_permission = true
# Web 通知图标 / Web notification icon ("default" or custom URL)
web_icon = "default"
# Web 通知显示时长（毫秒）/ Web notification display duration (ms) - range [1, 600000]
web_timeout = 5000
# 桌面系统通知 / Desktop system notification (plyer, optional; off by default to avoid unexpected popups)
system_enabled = false
# macOS 原生通知 / macOS native notification (primarily triggered by VS Code/Cursor plugin; backend field for config consistency)
macos_native_enabled = true
# 声音通知 / Sound notification
sound_enabled = true
sound_mute = false
# 声音文件 / Sound file (default: "default"; options: "deng" etc., depends on sounds resources)
sound_file = "default"
# 声音音量 / Sound volume - range [0, 100], out-of-range values auto-clamped
sound_volume = 80
# 移动端优化 / Mobile optimization
mobile_optimized = true
mobile_vibrate = true
# Bark 推送通知配置 / Bark push notification settings
bark_enabled = false
# Bark 服务器 URL / Bark server URL - must start with http:// or https://
bark_url = ""
# Bark 设备密钥 / Bark device key - required when bark_enabled=true
bark_device_key = ""
# Bark 通知图标 URL / Bark notification icon URL (optional)
bark_icon = ""
# Bark 通知动作 / Bark click action - valid: none / url (open link) / copy
bark_action = "none"
# Bark 点击 URL 模板 / Bark click URL template
# Effective when bark_action = "url" and the event does not provide an explicit URL.
# Supported placeholders: {task_id}, {event_id}, {base_url}
# Default opens the Web UI/PWA directly at the task created by the notification.
bark_url_template = "{base_url}/?task_id={task_id}"
# 发送失败重试次数 / Retry count on send failure (excluding first attempt) - range [0, 10]
retry_count = 3
# 重试间隔(秒) / Retry interval (seconds) - range [0, 60]
retry_delay = 2
# Bark 请求超时(秒) / Bark request timeout (seconds) - range [1, 300]
bark_timeout = 10

# ──────────────────────────────────────────────
# Web 界面配置 / Web UI Settings
# ──────────────────────────────────────────────
[web_ui]
# 界面语言 / UI Language
# - "auto": 自动检测 / Auto-detect (browser navigator.language / VS Code vscode.env.language)
# - "en": English
# - "zh-CN": 简体中文 / Simplified Chinese
language = "auto"
# Web 服务监听地址 / Web server listen address (overridden by network_security.bind_interface)
host = "127.0.0.1"
# Web 服务端口 / Web server port - range [1, 65535], ports <1024 require admin privileges
port = 8080
# 调试模式 / Debug mode
debug = false
# HTTP 请求超时(秒) / HTTP request timeout (seconds) - range [1, 600]
http_request_timeout = 30
# HTTP 最大重试次数 / HTTP max retries - range [0, 20]
http_max_retries = 3
# HTTP 重试延迟(秒) / HTTP retry delay (seconds) - range [0, 60]
http_retry_delay = 1.0
# 外部访问基地址 / External base URL for notification click links and reverse proxies.
# Leave empty to prefer mDNS http://{mdns.hostname}:{port} when available, then fall back
# to http://{host}:{port}. Set explicitly for reverse proxies, HTTPS, or a custom LAN host.
external_base_url = ""

# ──────────────────────────────────────────────
# 网络安全配置 / Network Security Settings
# ──────────────────────────────────────────────
[network_security]
# 绑定网络接口 / Bind network interface (127.0.0.1=local only, 0.0.0.0=all interfaces)
bind_interface = "0.0.0.0"
# 允许访问的网络段 / Allowed network segments
allowed_networks = [
    "127.0.0.0/8",       # Loopback / 本地回环
    "::1/128",           # IPv6 loopback / IPv6 本地回环
    "192.168.0.0/16",    # Private / 私有网络
    "10.0.0.0/8",        # Private / 私有网络
    "172.16.0.0/12",     # Private / 私有网络
]
# IP 黑名单 / IP blacklist
blocked_ips = []
# 访问控制开关 / Access control switch
access_control_enabled = true

# ──────────────────────────────────────────────
# mDNS 配置 / mDNS Settings (for ai.local access & LAN service discovery)
# ──────────────────────────────────────────────
[mdns]
# 是否启用 mDNS / Enable mDNS
# - true: 强制启用 / Force enable
# - false: 强制禁用 / Force disable
# - "auto": 自动 / Auto (enabled when bind_interface is not 127.0.0.1/localhost/::1)
enabled = "auto"
# mDNS 主机名 / mDNS hostname (default: ai.local)
# 浏览器可直接访问 / Browser can access directly: http://ai.local:8080
hostname = "ai.local"
# DNS-SD 服务实例名 / DNS-SD service instance name (for service discovery, e.g. avahi-browse / dns-sd)
service_name = "AI Intervention Agent"

# ──────────────────────────────────────────────
# 反馈配置 / Feedback Settings
# 超时计算规则 / Timeout calculation:
# - frontend_countdown <= 0: backend_wait = max(backend_max_wait, 260s)
# - otherwise: backend_wait = min(max(frontend_countdown + 40s, 260s), backend_max_wait)
# ──────────────────────────────────────────────
[feedback]
# 后端最大等待时间(秒) / Backend max wait time (seconds) - range [10, 7200]
# 限制后端轮询最大时间 / Limits max backend polling time to prevent indefinite wait
backend_max_wait = 600
# 前端自动重调倒计时(秒) / Frontend auto-reschedule countdown (seconds) - range [10, 3600], 0=disabled
# 参考 Cursor 5分钟超时 / Based on Cursor 5-min session timeout, recommend 4 min (240s)
frontend_countdown = 240
# 错误/超时时的提示语 / Prompt on error/timeout (guides AI to re-invoke the tool)
# 空字符串使用默认值 / Empty string uses default, max 500 chars
resubmit_prompt = "请立即调用 interactive_feedback 工具"
# 追加到反馈末尾的提示语 / Suffix appended to user feedback (maintains session continuity)
# 可为空字符串 / Can be empty, max 500 chars
prompt_suffix = "\n请积极调用 interactive_feedback 工具"
